{
  "name": "be",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "build": "expo export --platform all --output-dir dist --clear",
    "apk": "CI=1 npx expo prebuild --platform android --no-install && cd android && ./gradlew assembleRelease",
    "apk:debug": "CI=1 npx expo prebuild --platform android --no-install && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.7",
    "buffer": "^6.0.3",
    "expo": "~55.0.3",
    "expo-camera": "^55.0.11",
    "expo-status-bar": "~55.0.5",
    "mqtt": "^5.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.83.4",
    "react-native-ble-plx": "^3.2.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "~55.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.0.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "private": true
}
